{
  "name": "translect",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Chromium extension for translating text inside webpage images with an OpenAI-compatible vision endpoint.",
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "node scripts/build.mjs --watch",
    "install:macos-ocr-host": "node scripts/install-macos-vision-host.mjs",
    "test": "vitest run",
    "test:scenarios": "node scripts/verify-scenarios.mjs"
  },
  "devDependencies": {
    "esbuild": "^0.25.4",
    "playwright": "^1.59.1",
    "vitest": "^3.2.4"
  }
}
